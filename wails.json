{
    "$schema": "https://wails.io/schemas/config.v2.json",
    "version": "2",
    "name": "Game Radar",
    "outputfilename": "game-radar",
    "build:dir": "build",
    "frontend:dir": "frontend",
    "frontend:install": "npm ci",
    "frontend:build": "npm run build",
    "frontend:dev:install": "npm ci",
    "frontend:dev:build": "npm run build",
    "frontend:dev:watcher": "npm run dev",
    "frontend:dev:serverUrl": "auto",
    "viteServerTimeout": 20,
    "debounceMS": 100,
    "nsisType": "multiple",
    "author": {
        "name": "Danil Solovyov",
        "email": "solovyovdanil@yandex.ru"
    },
    "info": {
        "companyName": "Danil Solovyov",
        "productName": "Game Radar",
        "productVersion": "1.0.0",
        "comments": "Directional sound radar overlay for Windows, built with Wails."
    }
}